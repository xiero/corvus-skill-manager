{
  "name": "@corvus-tools/skill-manager-tui",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Ink TUI for Corvus Skill Manager.",
  "license": "MIT",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "dist/**/*.d.ts.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "@corvus-tools/skill-manager-core": "workspace:^",
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "react-test-renderer": "^18.3.1"
  }
}
