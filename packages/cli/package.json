{
  "name": "@corvus-tools/skill-manager",
  "version": "0.3.1",
  "private": false,
  "type": "module",
  "description": "Run the Corvus Skill Manager Ink TUI with npx @corvus-tools/skill-manager.",
  "license": "MIT",
  "main": "./dist/index.js",
  "bin": {
    "corvus-skills": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "dist/**/*.d.ts.map",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "dev": "tsx --conditions development src/index.ts"
  },
  "dependencies": {
    "@corvus-tools/skill-manager-tui": "workspace:^",
    "ink": "^5.1.0",
    "react": "^18.3.1"
  }
}
